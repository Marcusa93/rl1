# ===== Supabase =====
# Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# (opcional, mismo valor que SUPABASE_URL, expuesto al cliente)
NEXT_PUBLIC_SUPABASE_URL=

# ===== OpenRouter (optimizador COTIO + comparador de demanda) =====
OPENROUTER_API_KEY=
# Modelo por defecto (cualquier id válido de OpenRouter)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ===== App =====
# Clave para entrar al panel del docente
TEACHER_PASSWORD=rl1-docente
# URL pública (usada en headers de OpenRouter)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
